---
import { ScrollArea } from '@/components/ui/scroll-area'

interface Props {
  headings?: { depth: number; slug: string; text: string }[]
}

const { headings = [] } = Astro.props

// Filter to only h2 and h3 headings
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3)

// Group h3 headings under their parent h2
interface TocItem {
  slug: string
  text: string
  depth: number
  children: TocItem[]
}

const groupedHeadings: TocItem[] = []
let currentH2: TocItem | null = null

tocHeadings.forEach(heading => {
  if (heading.depth === 2) {
    currentH2 = {
      slug: heading.slug,
      text: heading.text,
      depth: heading.depth,
      children: []
    }
    groupedHeadings.push(currentH2)
  } else if (heading.depth === 3 && currentH2) {
    currentH2.children.push({
      slug: heading.slug,
      text: heading.text,
      depth: heading.depth,
      children: []
    })
  }
})
---

{
  groupedHeadings.length > 0 && (
    <div class='sticky top-24'>
      <h3 class='text-foreground mb-3.5 font-medium'>On This Page</h3>
      <ScrollArea className='max-h-[calc(100vh-8rem)]'>
        <nav>
          <ul class='space-y-3'>
            {groupedHeadings.map(item => (
              <li>
                <a
                  href={`#${item.slug}`}
                  class='toc-link text-muted-foreground hover:text-foreground flex items-start gap-2 text-left transition-colors'
                  data-heading-link={item.slug}
                  data-depth='0'
                >
                  <span
                    class='toc-indicator bg-primary/40 mt-2.5 inline-block h-0.5 w-3 shrink-0 transition-colors'
                    data-link={item.slug}
                  />
                  <span>{item.text}</span>
                </a>

                {item.children.length > 0 && (
                  <ul class='mt-3 ml-5 space-y-3'>
                    {item.children.map(child => (
                      <li>
                        <a
                          href={`#${child.slug}`}
                          class='toc-link text-muted-foreground hover:text-foreground flex items-start gap-2 text-left transition-colors'
                          data-heading-link={child.slug}
                          data-depth='1'
                        >
                          <span
                            class='toc-indicator bg-primary/40 mt-2.5 inline-block h-0.5 w-3 shrink-0 transition-colors'
                            data-link={child.slug}
                          />
                          <span>{child.text}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </nav>
      </ScrollArea>
    </div>
  )
}

<script>
  const HEADER_OFFSET = 110

  const initializeToc = () => {
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link')
    const sections = document.querySelectorAll<HTMLElement>('h2[id], h3[id]')
    let activeId = ''

    const updateActiveLink = () => {
      links.forEach(link => {
        const linkHref = link.getAttribute('href')
        const indicator = link.querySelector('.toc-indicator')

        if (linkHref === `#${activeId}`) {
          link.classList.add('font-medium', 'text-foreground')
          link.classList.remove('text-muted-foreground')
          if (indicator) {
            indicator.classList.add('bg-primary')
            indicator.classList.remove('bg-primary/40')
          }
        } else {
          link.classList.remove('font-medium', 'text-foreground')
          link.classList.add('text-muted-foreground')
          if (indicator) {
            indicator.classList.remove('bg-primary')
            indicator.classList.add('bg-primary/40')
          }
        }
      })
    }

    // Function to find active heading based on scroll position
    const findActiveHeading = () => {
      const scrollY = window.scrollY
      let foundId = ''

      // Find the last heading above the scroll position
      for (let i = sections.length - 1; i >= 0; i--) {
        const section = sections[i]
        const sectionTop = section.getBoundingClientRect().top + scrollY
        if (sectionTop - HEADER_OFFSET <= scrollY) {
          foundId = section.id
          break
        }
      }

      // If no heading found, use the first one
      if (!foundId && sections.length > 0) {
        foundId = sections[0].id
      }

      if (foundId !== activeId) {
        activeId = foundId
        updateActiveLink()
      }
    }

    // Add click event for smooth scrolling
    links.forEach(link => {
      link.addEventListener('click', e => {
        e.preventDefault()
        const href = link.getAttribute('href')
        if (href) {
          const target = document.querySelector(href)
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' })
            activeId = href.substring(1)
            updateActiveLink()
          }
        }
      })
    })

    // Set initial active heading
    setTimeout(() => {
      findActiveHeading()
    }, 50)

    // Use scroll listener for more reliable heading detection
    const scrollHandler = () => {
      findActiveHeading()
    }

    window.addEventListener('scroll', scrollHandler, { passive: true })
  }

  document.addEventListener('astro:page-load', initializeToc)
</script>
